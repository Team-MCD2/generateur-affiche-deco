# ============================================================
# Configuration DecoShop Affiches
# ------------------------------------------------------------
# Copie ce fichier en `.env` (sans le `.example`) et remplis
# les valeurs reelles. NE COMMIT PAS le .env reel.
#
# Le serveur fonctionne en DEUX MODES (auto-detection) :
#   - STANDALONE : utilise SHOPIFY_SHOP + SHOPIFY_ADMIN_TOKEN
#                  (lance via `npm start`)
#   - EMBEDDED   : utilise SHOPIFY_API_KEY + SHOPIFY_API_SECRET
#                  (lance via `shopify app dev`, qui injecte
#                  automatiquement HOST, PORT, SCOPES)
# ============================================================

# ----------------------------------------------------------------
# MODE STANDALONE (Custom App admin token)
# ----------------------------------------------------------------

# Domaine .myshopify.com de la boutique.
SHOPIFY_SHOP=decoshop311.myshopify.com

# Token Admin API d'une "Custom App" (Shopify Admin > Apps >
# Develop apps > Create an app > Admin API access token).
# Scope minimum : read_products. Format : commence par `shpat_`.
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Optionnel) Domaine public utilise pour construire l'URL
# du QR code quand `onlineStoreUrl` n'est pas dispo.
SHOPIFY_PUBLIC_DOMAIN=decoshop.fr

# ----------------------------------------------------------------
# MODE EMBEDDED (app Shopify, OAuth)
# ----------------------------------------------------------------
# Ces vars sont normalement injectees par Shopify CLI. Tu les
# trouves aussi dans Partners Dashboard > ton app > API credentials
# apres `shopify app config link`.
#
# Si SHOPIFY_API_KEY et SHOPIFY_API_SECRET sont presents,
# le serveur active automatiquement le mode embedded (OAuth +
# App Bridge + iframe admin Shopify).
# ----------------------------------------------------------------

# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SCOPES=read_products
# HOST=https://xxxx.trycloudflare.com
