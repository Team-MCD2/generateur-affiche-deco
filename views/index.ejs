<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Generateur d'affiches — DecoShop Toulouse</title>
  <!-- Favicons : .ico DecoShop officiel + PNG pour retina / iOS -->
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/logo.png" />
  <link rel="apple-touch-icon" href="/assets/logo.png" />

  <!-- Polices DecoShop : Playfair Display (titres) + DM Sans (texte) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;700&display=swap"
  />

  <link rel="stylesheet" href="/styles.css" />

  <!-- @page : toujours A4 paysage, marges nulles. -->
  <style>@page { size: A4 landscape; margin: 0; }</style>
</head>
<body>

  <%- include('partials/header') %>

  <!-- ====================================================== -->
  <!-- LAYOUT PRINCIPAL : 2 colonnes (form | apercu A4)        -->
  <!-- ====================================================== -->
  <main class="app-grid no-print">
    <%- include('partials/form') %>
    <%- include('partials/preview') %>
  </main>

  <%- include('partials/label-template') %>

  <script src="/app.js"></script>
</body>
</html>
