<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Generateur d'etiquettes — DecoShop Toulouse</title>
  <link rel="icon" type="image/png" href="/assets/logo.png" />

  <!-- Polices DecoShop : Playfair Display (titres) + DM Sans (texte) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;700&display=swap"
  />

  <link rel="stylesheet" href="/styles.css" />

  <!-- @page dynamique : remplace par JS selon l'orientation choisie. -->
  <style id="pageStyle">@page { size: A4 portrait; margin: 0; }</style>
</head>
<body>

  <%- include('partials/header') %>

  <!-- ====================================================== -->
  <!-- LAYOUT PRINCIPAL : 3 colonnes                           -->
  <!-- ====================================================== -->
  <main class="app-grid no-print">
    <%- include('partials/form') %>
    <%- include('partials/preview') %>
    <%- include('partials/sheet') %>
  </main>

  <%- include('partials/print-area') %>
  <%- include('partials/label-template') %>

  <script src="/app.js"></script>
</body>
</html>
