<!-- ============================================================ -->
<!-- FORM > Section "Style etiquette" : fond + accent + badge + icone -->
<!-- ============================================================ -->

<!-- Couleur de fond de l'etiquette -->
<div class="field">
  <label class="field__group-label">Couleur de fond</label>
  <div class="chip-grid" role="radiogroup" aria-label="Couleur de fond de l'etiquette">
    <label class="chip-option">
      <input type="radio" name="bg" value="white" checked />
      <span class="chip chip--bg-white" aria-hidden="true"></span>
      <span class="chip-label">Blanc</span>
    </label>
    <label class="chip-option">
      <input type="radio" name="bg" value="cream" />
      <span class="chip chip--bg-cream" aria-hidden="true"></span>
      <span class="chip-label">Creme</span>
    </label>
    <label class="chip-option">
      <input type="radio" name="bg" value="sand" />
      <span class="chip chip--bg-sand" aria-hidden="true"></span>
      <span class="chip-label">Sable</span>
    </label>
    <label class="chip-option">
      <input type="radio" name="bg" value="rose" />
      <span class="chip chip--bg-rose" aria-hidden="true"></span>
      <span class="chip-label">Rose</span>
    </label>
    <label class="chip-option">
      <input type="radio" name="bg" value="sky" />
      <span class="chip chip--bg-sky" aria-hidden="true"></span>
      <span class="chip-label">Bleu</span>
    </label>
    <label class="chip-option">
      <input type="radio" name="bg" value="sage" />
      <span class="chip chip--bg-sage" aria-hidden="true"></span>
      <span class="chip-label">Sauge</span>
    </label>
  </div>
</div>

<!-- Couleur d'accent (bloc prix + nom marque) -->
<div class="field">
  <label class="field__group-label">Couleur du bloc prix</label>
  <div class="chip-grid" role="radiogroup" aria-label="Couleur d'accent">
    <label class="chip-option">
      <input type="radio" name="accent" value="navy" checked />
      <span class="chip chip--accent-navy" aria-hidden="true"></span>
      <span class="chip-label">Navy</span>
    </label>
    <label class="chip-option">
      <input type="radio" name="accent" value="yellow" />
      <span class="chip chip--accent-yellow" aria-hidden="true"></span>
      <span class="chip-label">Jaune</span>
    </label>
    <label class="chip-option">
      <input type="radio" name="accent" value="red" />
      <span class="chip chip--accent-red" aria-hidden="true"></span>
      <span class="chip-label">Rouge</span>
    </label>
    <label class="chip-option">
      <input type="radio" name="accent" value="black" />
      <span class="chip chip--accent-black" aria-hidden="true"></span>
      <span class="chip-label">Noir</span>
    </label>
    <label class="chip-option">
      <input type="radio" name="accent" value="forest" />
      <span class="chip chip--accent-forest" aria-hidden="true"></span>
      <span class="chip-label">Foret</span>
    </label>
    <label class="chip-option">
      <input type="radio" name="accent" value="terracotta" />
      <span class="chip chip--accent-terracotta" aria-hidden="true"></span>
      <span class="chip-label">Terracotta</span>
    </label>
  </div>
</div>

<!-- Badge predefini -->
<div class="field">
  <label class="field__group-label">Badge</label>
  <div class="badge-grid" role="radiogroup" aria-label="Badge de l'etiquette">
    <label class="badge-option">
      <input type="radio" name="badge" value="" checked />
      <span class="badge-card badge-card--none">Aucun</span>
    </label>
    <label class="badge-option">
      <input type="radio" name="badge" value="new" />
      <span class="badge-card badge-card--new">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.582a.5.5 0 0 1 0 .962L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/></svg>
        <span>Nouveau</span>
      </span>
    </label>
    <label class="badge-option">
      <input type="radio" name="badge" value="promo" />
      <span class="badge-card badge-card--promo">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
        <span>Promo</span>
      </span>
    </label>
    <label class="badge-option">
      <input type="radio" name="badge" value="love" />
      <span class="badge-card badge-card--love">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/></svg>
        <span>Coup de coeur</span>
      </span>
    </label>
    <label class="badge-option">
      <input type="radio" name="badge" value="bio" />
      <span class="badge-card badge-card--bio">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.3c1 1 1 2.4-.4 3.4-1.6 1.2-1.4 4.4 0 6 1.5 1.7 1 5.5-2 7.4-3 1.8-7 1.5-7-.4"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
        <span>Bio</span>
      </span>
    </label>
    <label class="badge-option">
      <input type="radio" name="badge" value="local" />
      <span class="badge-card badge-card--local">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span>Local</span>
      </span>
    </label>
    <label class="badge-option">
      <input type="radio" name="badge" value="exclu" />
      <span class="badge-card badge-card--exclu">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        <span>Exclu</span>
      </span>
    </label>
  </div>
</div>

<!-- Symbole decoratif libre -->
<div class="field">
  <label class="field__group-label">Symbole decoratif</label>
  <div class="icon-grid" role="radiogroup" aria-label="Symbole decoratif de l'etiquette">
    <label class="icon-option">
      <input type="radio" name="icon" value="" checked />
      <span class="icon-card icon-card--none" title="Aucun symbole">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
      </span>
    </label>
    <label class="icon-option">
      <input type="radio" name="icon" value="star" />
      <span class="icon-card" title="Etoile">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </span>
    </label>
    <label class="icon-option">
      <input type="radio" name="icon" value="heart" />
      <span class="icon-card" title="Coeur">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linejoin="round" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/></svg>
      </span>
    </label>
    <label class="icon-option">
      <input type="radio" name="icon" value="flame" />
      <span class="icon-card" title="Flamme">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linejoin="round" aria-hidden="true"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
      </span>
    </label>
    <label class="icon-option">
      <input type="radio" name="icon" value="leaf" />
      <span class="icon-card" title="Feuille">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.3c1 1 1 2.4-.4 3.4-1.6 1.2-1.4 4.4 0 6 1.5 1.7 1 5.5-2 7.4-3 1.8-7 1.5-7-.4"/></svg>
      </span>
    </label>
    <label class="icon-option">
      <input type="radio" name="icon" value="sparkles" />
      <span class="icon-card" title="Etincelles">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" aria-hidden="true"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.582a.5.5 0 0 1 0 .962L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
      </span>
    </label>
    <label class="icon-option">
      <input type="radio" name="icon" value="gift" />
      <span class="icon-card" title="Cadeau">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5C11 3 12 8 12 8s1-5 4.5-5a2.5 2.5 0 0 1 0 5"/></svg>
      </span>
    </label>
    <label class="icon-option">
      <input type="radio" name="icon" value="crown" />
      <span class="icon-card" title="Couronne">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linejoin="round" aria-hidden="true"><path d="m2 4 3 12h14l3-12-6 7-4-7-4 7-6-7zm3 16h14"/></svg>
      </span>
    </label>
  </div>
</div>
