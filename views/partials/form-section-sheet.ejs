<!-- ============================================================ -->
<!-- FORM > Section "Planche" : format + orientation + couleur    -->
<!-- ============================================================ -->

<!-- Selecteur de format de planche -->
<div class="field">
  <label class="field__group-label">Format de planche A4</label>
  <div class="format-grid" role="radiogroup" aria-label="Nombre d'etiquettes par planche">
    <label class="format-option">
      <input type="radio" name="format" value="1" />
      <span class="format-card">
        <span class="format-card__num">1</span>
        <span class="format-card__layout" aria-hidden="true">
          <span class="format-cell"></span>
        </span>
        <span class="format-card__text">XL</span>
      </span>
    </label>
    <label class="format-option">
      <input type="radio" name="format" value="2" />
      <span class="format-card">
        <span class="format-card__num">2</span>
        <span class="format-card__layout format-card__layout--cols-1 format-card__layout--rows-2" aria-hidden="true">
          <span class="format-cell"></span><span class="format-cell"></span>
        </span>
        <span class="format-card__text">L</span>
      </span>
    </label>
    <label class="format-option">
      <input type="radio" name="format" value="3" />
      <span class="format-card">
        <span class="format-card__num">3</span>
        <span class="format-card__layout format-card__layout--cols-1 format-card__layout--rows-3" aria-hidden="true">
          <span class="format-cell"></span><span class="format-cell"></span><span class="format-cell"></span>
        </span>
        <span class="format-card__text">M</span>
      </span>
    </label>
    <label class="format-option">
      <input type="radio" name="format" value="4" />
      <span class="format-card">
        <span class="format-card__num">4</span>
        <span class="format-card__layout format-card__layout--cols-2 format-card__layout--rows-2" aria-hidden="true">
          <span class="format-cell"></span><span class="format-cell"></span>
          <span class="format-cell"></span><span class="format-cell"></span>
        </span>
        <span class="format-card__text">M</span>
      </span>
    </label>
    <label class="format-option">
      <input type="radio" name="format" value="5" />
      <span class="format-card">
        <span class="format-card__num">5</span>
        <span class="format-card__layout format-card__layout--cols-2 format-card__layout--rows-3 format-card__layout--five" aria-hidden="true">
          <span class="format-cell"></span><span class="format-cell"></span>
          <span class="format-cell"></span><span class="format-cell"></span>
          <span class="format-cell format-cell--centered"></span>
        </span>
        <span class="format-card__text">S</span>
      </span>
    </label>
    <label class="format-option">
      <input type="radio" name="format" value="6" checked />
      <span class="format-card">
        <span class="format-card__num">6</span>
        <span class="format-card__layout format-card__layout--cols-2 format-card__layout--rows-3" aria-hidden="true">
          <span class="format-cell"></span><span class="format-cell"></span>
          <span class="format-cell"></span><span class="format-cell"></span>
          <span class="format-cell"></span><span class="format-cell"></span>
        </span>
        <span class="format-card__text">S</span>
      </span>
    </label>
  </div>
  <small class="hint">Choisis la quantite et la taille des etiquettes que tu veux imprimer sur ta feuille A4.</small>
</div>

<!-- Orientation Portrait / Paysage -->
<div class="field">
  <label class="field__group-label">Orientation de la feuille</label>
  <div class="orient-grid" role="radiogroup" aria-label="Orientation A4">
    <label class="orient-option">
      <input type="radio" name="orient" value="portrait" checked />
      <span class="orient-card">
        <span class="orient-card__icon" aria-hidden="true">
          <svg width="18" height="22" viewBox="0 0 18 22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
            <rect x="1" y="1" width="16" height="20" rx="1.5"/>
            <line x1="4" y1="6" x2="14" y2="6"/>
            <line x1="4" y1="10" x2="14" y2="10"/>
            <line x1="4" y1="14" x2="11" y2="14"/>
          </svg>
        </span>
        <span class="orient-card__label">Portrait</span>
        <small class="orient-card__hint">210 × 297 mm</small>
      </span>
    </label>
    <label class="orient-option">
      <input type="radio" name="orient" value="landscape" />
      <span class="orient-card">
        <span class="orient-card__icon" aria-hidden="true">
          <svg width="22" height="18" viewBox="0 0 22 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
            <rect x="1" y="1" width="20" height="16" rx="1.5"/>
            <line x1="4" y1="5" x2="18" y2="5"/>
            <line x1="4" y1="9" x2="18" y2="9"/>
            <line x1="4" y1="13" x2="14" y2="13"/>
          </svg>
        </span>
        <span class="orient-card__label">Paysage</span>
        <small class="orient-card__hint">297 × 210 mm</small>
      </span>
    </label>
  </div>
  <small class="hint">En paysage, les formats 2, 3, 5 et 6 se reorganisent en colonnes pour mieux remplir la feuille.</small>
</div>

<!-- Couleur de la planche A4 (global) -->
<div class="field">
  <label class="field__group-label">Couleur de la planche A4</label>
  <div class="chip-grid" role="radiogroup" aria-label="Couleur de la planche A4">
    <label class="chip-option">
      <input type="radio" name="paper" value="white" checked />
      <span class="chip chip--paper-white" aria-hidden="true"></span>
      <span class="chip-label">Blanc</span>
    </label>
    <label class="chip-option">
      <input type="radio" name="paper" value="cream" />
      <span class="chip chip--paper-cream" aria-hidden="true"></span>
      <span class="chip-label">Creme</span>
    </label>
    <label class="chip-option">
      <input type="radio" name="paper" value="kraft" />
      <span class="chip chip--paper-kraft" aria-hidden="true"></span>
      <span class="chip-label">Kraft</span>
    </label>
    <label class="chip-option">
      <input type="radio" name="paper" value="rose" />
      <span class="chip chip--paper-rose" aria-hidden="true"></span>
      <span class="chip-label">Rose</span>
    </label>
    <label class="chip-option">
      <input type="radio" name="paper" value="sky" />
      <span class="chip chip--paper-sky" aria-hidden="true"></span>
      <span class="chip-label">Bleu</span>
    </label>
    <label class="chip-option">
      <input type="radio" name="paper" value="mint" />
      <span class="chip chip--paper-mint" aria-hidden="true"></span>
      <span class="chip-label">Menthe</span>
    </label>
  </div>
  <small class="hint">S'applique a toute la planche, visible a l'ecran et a l'impression.</small>
</div>
