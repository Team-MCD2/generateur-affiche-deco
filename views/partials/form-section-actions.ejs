<!-- ============================================================ -->
<!-- FORM > Section "Actions" : impression directe + reset          -->
<!-- (la case Modele expose a migre dans form-section-style.ejs)    -->
<!-- ============================================================ -->

<div class="form__actions">
  <button id="btn-generate-qr" type="button" class="btn btn--secondary">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><rect x="7" y="7" width="3" height="3"/><rect x="14" y="7" width="3" height="3"/><rect x="7" y="14" width="3" height="3"/><rect x="14" y="14" width="3" height="3"/></svg>
    Générer un QR code
  </button>
  <button id="btnPrint" type="submit" class="btn btn--primary">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
    Imprimer l'affiche
  </button>
  <button id="btnReset" type="reset" class="btn btn--ghost">
    Reinitialiser
  </button>
</div>

<p id="formError" class="form__error" role="alert" hidden></p>
<p class="form__tip">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
  <span>Choisis <strong>Marges : Aucunes</strong> et <strong>Echelle : 100&nbsp;%</strong> dans le dialogue d'impression pour un rendu A4 paysage 1:1.</span>
</p>
